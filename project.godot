; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Drunkpowder"
run/main_scene="uid://cgskbsomutq37"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Global="*uid://dy1ojf8nkaw88"
Audio="*uid://dul8k1s6tteau"

[debug]

settings/stdout/print_fps=true

[display]

window/size/viewport_width=240
window/size/viewport_height=160
window/size/resizable=false
window/size/window_width_override=960
window/size/window_height_override=640
window/stretch/mode="viewport"

